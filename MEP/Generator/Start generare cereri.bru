meta {
  name: Start generare cereri
  type: http
  seq: 1
}

post {
  url: http://localhost:8090/generator/start?scenario=&rps=750&duration=10
  body: none
  auth: inherit
}

params:query {
  scenario: 
  rps: 750
  duration: 10
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Configuratii:
  - scenario:
    - burst
    - gradual
    - fara optiune => uniform
  - rps (requests per second)
  - duration (cat dureaza experimentul in secundeß)
}
